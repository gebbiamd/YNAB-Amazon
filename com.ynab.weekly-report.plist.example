<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.ynab.weekly-report</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/stephengebbiaii/Projects/YNAB Amazon/run_weekly_budget_report.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/stephengebbiaii/Projects/YNAB Amazon</string>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key>
    <integer>1</integer>
    <key>Hour</key>
    <integer>8</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/stephengebbiaii/Projects/YNAB Amazon/logs/weekly_report.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/stephengebbiaii/Projects/YNAB Amazon/logs/weekly_report.err.log</string>
  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
