# Gmail query override (optional)
# gmail_query=in:"YNAB Amazon" newer_than:90d

# YNAB
ynab_api_key=YOUR_YNAB_PERSONAL_ACCESS_TOKEN
ynab_budget_id=YOUR_BUDGET_ID
# Optional: scope to one account; omit to scan all budget accounts
# ynab_account_id=YOUR_ACCOUNT_ID

# Only process transactions with this payee name
ynab_payee_name_to_be_processed=Amazon: Needs Memo
# Rename payee to this after memo processing (optional)
ynab_payee_name_processing_completed=Amazon

# Memo formatting
ynab_use_markdown=true
# Split behavior for non-memo visual separation in YNAB register:
# - true/false master switch
# - strategy: conservative | all | off
ynab_use_splits=true
ynab_split_strategy=conservative

# AI memo/category generation
use_ai_summarization=true
openai_api_key=YOUR_OPENAI_API_KEY
# Optional model override
# openai_model=gpt-4o-mini

# Weekly report settings
REPORT_MONTHS=6
REPORT_OUTPUT_HTML=reports/weekly_budget_report.html
REPORT_EMAIL_TO=you@example.com
REPORT_EMAIL_SUBJECT=Weekly Budget Insights
REPORT_DEBUG_LOG=logs/weekly_report_debug.json
DASHBOARD_BASE_URL=http://127.0.0.1:5001
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5001
# Optional Gmail OAuth file overrides
# GMAIL_CREDENTIALS_FILE=credentials.json
# GMAIL_SEND_TOKEN_FILE=token_send.json
